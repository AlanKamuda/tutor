# Required: Gemini API access. Get one at https://aistudio.google.com/apikey
GOOGLE_API_KEY=your-gemini-api-key-here
GOOGLE_GENAI_USE_VERTEXAI=FALSE

# Optional: enables the YouTube resource-search tool. Without this, the
# Resource Finder agent silently falls back to arXiv/web search.
# https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=

# Optional: enables general web search (Tavily-compatible). Without this,
# the Resource Finder agent falls back to arXiv/YouTube only.
# https://tavily.com
WEB_SEARCH_API_KEY=

# Tunables (defaults shown)
TUTOR_MODEL=gemini-2.5-flash
TUTOR_MASTERY_THRESHOLD=0.75
TUTOR_MAX_REMEDIATION_LOOPS=3
